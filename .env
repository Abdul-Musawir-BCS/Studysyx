# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Required in production. Signs sessions, CSRF tokens, and password-reset
# links. Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# If left blank, app.py will generate a random one at process start (dev only —
# every restart invalidates existing sessions).
SECRET_KEY=

# Set to "production" to require HTTPS-only session cookies. Leave unset for local dev.
FLASK_ENV=

# Used for BOTH "Sign in with Google" (auth/google/*, fully working) and, once
# you build it out, real Google Classroom data sync (/api/google-sync, stubbed).
# Create these at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI to register: http://localhost:5000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
